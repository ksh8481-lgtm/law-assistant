    {
      "law_id": "LAW_STEEPSLOPE",
      "law_name": "급경사지 재해예방에 관한 법률",
      "duties": [
        {
          "article": "제5조",
          "duty_title": "급경사지 안전점검 실시 및 결과 통보",
          "description": "관리기관은 소관 급경사지에 대하여 안전점검을 실시하고, 특별자치시장·시장·군수 또는 구청장에게 그 결과를 통보하여야 합니다.",
          "frequency": "연 2회 이상",
          "target": "급경사지 관리기관"
        },
        {
          "article": "제6조",
          "duty_title": "붕괴위험지역의 지정",
          "description": "시장등은 재해위험도평가 및 주민의견 수렴을 거쳐 붕괴위험지역을 지정하고 고시하여야 합니다.",
          "frequency": "수시 (위험 도출 시)",
          "target": "특별자치시장, 시장·군수·구청장"
        }
      ]
    },
    {
      "law_id": "LAW_FACILITY",
      "law_name": "시설물의 안전 및 유지관리에 관한 특별법",
      "duties": [
        {
          "article": "제11조",
          "duty_title": "정기안전점검 실시",
          "description": "관리주체는 소관 시설물에 대하여 정기적으로 안전점검을 실시하여야 합니다.",
          "frequency": "반기에 1회 이상 (등급에 따라 상이)",
          "target": "시설물 관리주체"
        },
        {
          "article": "제12조",
          "duty_title": "정밀안전점검 실시",
          "description": "관리주체는 시설물의 결함을 조기에 발견하기 위해 정밀안전점검을 실시하여야 합니다.",
          "frequency": "1~3년에 1회 이상 (등급/종별 상이)",
          "target": "시설물 관리주체"
        }
      ]
    },
    {
      "law_id": "LAW_OSHA",
      "law_name": "산업안전보건법",
      "duties": [
        {
          "article": "제29조",
          "duty_title": "근로자 안전보건교육 실시",
          "description": "사업주는 소속 근로자에게 정기적으로 안전보건교육을 실시하여야 합니다.",
          "frequency": "매 반기 (또는 매월)",
          "target": "사업주 (시공사 등)"
        },
        {
          "article": "제36조",
          "duty_title": "위험성평가의 실시",
          "description": "사업주는 건설물, 기계, 설비 등으로 인한 유해·위험요인을 찾아내어 위험성을 평가하고 조치해야 합니다.",
          "frequency": "최초 및 정기평가 (매년)",
          "target": "사업주"
        }
      ]
    },
    {
      "law_id": "LAW_NATURAL_DISASTER",
      "law_name": "자연재해대책법",
      "duties": [
        {
          "article": "제4조",
          "duty_title": "재해영향평가 등의 협의",
          "description": "관계 행정기관의 장은 개발계획 수립 시 재해영향에 관한 평가를 거쳐 행정안전부장관과 협의하여야 합니다.",
          "frequency": "개발사업 인가·승인 전",
          "target": "관계 행정기관의 장"
        }
